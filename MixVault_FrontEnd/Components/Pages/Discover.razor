@page "/discover"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@inject IHttpClientFactory HttpClientFactory
@inject MixVault_FrontEnd.Services.AudioState AudioState
@inject MixVault_FrontEnd.Services.Userstate Userstate
@inject NavigationManager NavigationManager
@inject ProtectedLocalStorage ProtectedLocalStore

<PageTitle>MixVault - Discover</PageTitle>

<style>
    /* De complete pagina blijft op zijn plek staan */
    html, body {
        max-width: 100vw;
        overflow-x: hidden;
    }

    /* Zorg dat de hoofdcontainer op beide schermen niks verbergt */
    .container-fluid {
        max-width: 100vw;
        overflow-x: visible !important;
        padding-left: 0 !important; /* Verwijder standaard Bootstrap padding */
        padding-right: 0 !important;
    }

    /* DE SCROLLBAR FIX MET EXTRA ADEMRUIMTE */
    .horizontal-scroll-wrapper {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: nowrap !important; /* Absoluut geen automatische breekpunten */

        overflow-x: auto !important; /* Forceer scrollfunctionaliteit */
        overflow-y: hidden !important; /* Voorkom verticaal scrollen */
        /* Zorgt dat hij op beide pagina's de volledige breedte pakt */
        width: 100% !important;
        max-width: 100% !important;
        gap: 1.5rem;
        padding-top: 10px;
        padding-bottom: 25px; /* Meer ademruimte */
        padding-left: 2rem !important; /* Geef de eerste kaart ruimte */
        padding-right: 3rem !important; /* VOEG DIT TOE: Zorgt dat de laatste kaart niet wegvalt! */

        scrollbar-width: thin !important;
        scrollbar-color: var(--accent-pink) #1e1e24 !important;
        -webkit-overflow-scrolling: touch;
        box-sizing: border-box !important;
    }

        /* Chrome, Edge, Brave & Safari custom scrollbar */
        .horizontal-scroll-wrapper::-webkit-scrollbar {
            height: 8px !important;
            display: block !important;
        }

        .horizontal-scroll-wrapper::-webkit-scrollbar-track {
            background: #1e1e24 !important;
            border-radius: 10px;
        }

        .horizontal-scroll-wrapper::-webkit-scrollbar-thumb {
            background-color: var(--accent-pink) !important;
            border-radius: 10px;
            cursor: pointer;
        }

    /* DE KAARTEN: Absolute breedte-restricties */
    .scroll-card {
        display: block !important;
        flex: 0 0 260px !important; /* Geen shrink, geen grow, basisbreedte */
        width: 260px !important;
        min-width: 260px !important; /* Voorkomt inkrimpen */
        box-sizing: border-box !important;
        cursor: pointer;
    }

    .section-title {
        font-weight: 800;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        padding-left: 2rem; /* Lijn de titel uit met de eerste kaart */
        color: var(--text-white);
    }
</style>
<div class="container-fluid mt-4 px-4">
    <h1 class="mb-4 fw-bold text-white">Ontdek Nieuwe Muziek</h1>

    @* Zoek & Filter in Paars/Roze stijl *@
    <div class="row mb-4 p-4 rounded shadow-sm mx-0" style="background-color: var(--bg-card); border: 1px solid rgba(255,255,255,0.1);">
        <div class="col-md-6">
            <input type="text" class="form-control bg-dark text-white border-0"
                   placeholder="🔍 Zoek op track, artiest of DJ..."
                   @bind="SearchText" @bind:event="oninput" style="border-radius: 8px;" />
        </div>
    </div>

    @* --- TRACKS (Horizontale scroll en uniforme paarse kaarten) --- *@
    <h3 class="section-title">🌍 Wereldwijde Tracks</h3>
    @if (filteredTracks != null)
    {
        @if (filteredTracks.Count == 0)
        {
            <p class="text-muted">Geen tracks gevonden die matchen met je zoekopdracht.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var track in filteredTracks)
                {
                    <div class="mv-card scroll-card p-3" @onclick="() => OpenTrackDetails(track)">
                        <h5 class="fw-bold text-truncate text-white mb-1">@track.Title</h5>
                        <p class="small mb-2" style="color: var(--text-soft);">
                            👤 @(string.IsNullOrEmpty(track.TrackArtist) ? track.UploaderName : track.TrackArtist)
                        </p>
                        <span class="badge rgba-pink-bg" style="color: var(--accent-pink); border: 1px solid var(--accent-pink);">@track.TrackGenre</span>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <p class="text-muted"><em>Tracks inladen...</em></p>
    }

    @* --- PLAYLISTS (Horizontale scroll en uniforme paarse kaarten) --- *@
    <h3 class="section-title">📂 Publieke Playlists</h3>
    @if (filteredPlaylists != null)
    {
        @if (filteredPlaylists.Count == 0)
        {
            <p class="text-muted">Geen publieke playlists gevonden.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var playlist in filteredPlaylists)
                {
                    <div class="mv-card scroll-card p-3" @onclick="() => OpenPlaylistDetails(playlist)">
                        <h5 class="fw-bold text-truncate text-white mb-1">@playlist.PlaylistName</h5>
                        <p class="small mb-2" style="color: var(--text-soft);">Genre: @playlist.PlaylistGenre</p>
                        <span class="badge bg-secondary">Publieke Lijst</span>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <p class="text-muted"><em>Playlists inladen...</em></p>
    }
</div>

@* --- UNIVERSELE UNIFORME MODAL: TRACK INFO --- *@
@if (selectedTrack != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: var(--bg-card); border: 1px solid var(--accent-pink); color: white;">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Track Details</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDetails"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <h2 class="fw-bold text-white mb-1">@selectedTrack.Title</h2>
                    <h4 class="mb-4" style="color: var(--accent-pink);">
                        👤 @(string.IsNullOrEmpty(selectedTrack.TrackArtist) ? selectedTrack.UploaderName : selectedTrack.TrackArtist)
                    </h4>
                    <p class="text-muted small">Gemixt/Geüpload door: @selectedTrack.UploaderName</p>

                    <div class="d-flex justify-content-center gap-2 mt-3">
                        @* Let op de hoofdletter G in TrackGenre! *@
                        <span class="badge bg-dark border border-secondary p-2">Genre: @selectedTrack.TrackGenre</span>
                        <span class="badge bg-dark border border-secondary p-2">
                            ⏳ @(selectedTrack.DurationMs.HasValue? Math.Round(selectedTrack.DurationMs.Value / 60000, 2).ToString("0.00") : "Onbekend") min
                        </span>
                    </div>

                    @if (!string.IsNullOrEmpty(actionMessage))
                    {
                        <div class="mt-3 small text-info fw-bold">✨ @actionMessage</div>
                    }
                </div>
                <div class="modal-footer border-0 d-flex flex-column gap-2">
                    <button class="btn btn-mv-accent w-100 py-2 fw-bold" @onclick="() => PlayTrack(selectedTrack)">
                        ▶ NU AFSPELEN
                    </button>

                    @* ALS JIJ DE UPLOADER BENT TOON VERWIJDERKNOP, ANDERS DE LIKE KNOP *@
                    @if (selectedTrack.UploaderName == Userstate.DisplayName)
                    {
                        <button class="btn btn-danger w-100 py-2 fw-bold" @onclick="DeleteUploadedTrack">
                            🗑️ VERWIJDEREN VAN SERVER
                        </button>
                    }
                    <button class="btn btn-outline-light w-100 mt-2" @onclick="async () => await LikeTrack(selectedTrack.TrackId)">
                        ❤️ Liken
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* --- UNIVERSELE UNIFORME MODAL: PLAYLIST INFO --- *@
@if (selectedPlaylist != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content" style="background-color: var(--bg-card); border: 1px solid var(--accent-pink); color: white;">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Playlist Info</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDetails"></button>
                </div>
                <div class="modal-body">
                    <h3 class="fw-bold text-white mb-1">@selectedPlaylist.PlaylistName</h3>
                    <p style="color: var(--text-soft);">@selectedPlaylist.PlaylistDescription</p>
                    <span class="badge rgba-pink-bg mb-3" style="color: var(--accent-pink);">Genre: @selectedPlaylist.PlaylistGenre</span>

                    <hr style="border-color: rgba(255,255,255,0.1);" />
                    <h5 class="fw-bold mb-3">Tracks in deze lijst</h5>

                    <div style="max-height: 250px; overflow-y: auto;">
                        @if (selectedPlaylist.Tracks != null && selectedPlaylist.Tracks.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var track in selectedPlaylist.Tracks)
                                {
                                    <div class="list-group-item bg-transparent text-white d-flex justify-content-between align-items-center border-secondary px-0">
                                        <div>
                                            <strong class="text-white">@(track.Position). @track.Title</strong><br />
                                            <small style="color: var(--text-soft);">⏳ @(track.Duration.HasValue? Math.Round(track.Duration.Value / 60000, 2).ToString("0.00") : "Onbekend") min</small>
                                        </div>
                                        <button class="btn btn-sm btn-mv-accent" @onclick="() => PlayPlaylistTrack(track)">▶</button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small">Deze lijst bevat nog geen nummers.</p>
                        }
                    </div>
                </div>
                <div class="modal-footer border-0 justify-content-center gap-2">
                    <button class="btn btn-mv-accent btn-lg px-4 fw-bold" @onclick="async () => PlayPlaylist(selectedPlaylist)">
                        ▶ Alles Afspelen
                    </button>
                    <button class="btn btn-outline-light btn-lg px-4" @onclick="() => LikePlaylist(selectedPlaylist.PlaylistId)">
                        ❤️ Playlist Volgen
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isCheckingLogin = true;
    private string actionMessage = "";

    // Data lijsten
    private List<TrackModel>? allTracks;
    private List<Playlistmodel>? allPlaylists;
    private List<TrackModel>? filteredTracks;
    private List<Playlistmodel>? filteredPlaylists;

    // Filter & Zoek variabelen
    private string _searchText = "";
    private string SearchText
    {
        get => _searchText;
        set { _searchText = value; FilterData(); }
    }

    private string SelectedGenre = "Alle";

    // Modals
    private TrackModel? selectedTrack;
    private Playlistmodel? selectedPlaylist;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                if (!Userstate.IsLoggedIn)
                {
                    var storedUserId = await ProtectedLocalStore.GetAsync<int>("userId");
                    var storedUserName = await ProtectedLocalStore.GetAsync<string>("userName");

                    if (storedUserId.Success && storedUserName.Success)
                    {
                        Userstate.LogIn(storedUserId.Value, storedUserName.Value);
                    }
                    else
                    {
                        NavigationManager.NavigateTo("/");
                        return;
                    }
                }
                await LoadMusicData();
            }
            catch (Exception)
            {
                NavigationManager.NavigateTo("/");
                return;
            }
            finally
            {
                isCheckingLogin = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadMusicData()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            allTracks = await client.GetFromJsonAsync<List<TrackModel>>("tracks");
            allPlaylists = await client.GetFromJsonAsync<List<Playlistmodel>>("playlists");

            FilterData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fout bij inladen data: {ex.Message}");
            allTracks = new(); allPlaylists = new();
            FilterData();
        }
    }

    private void FilterData()
    {
        if (allTracks != null)
        {
            filteredTracks = allTracks.Where(t =>
                (string.IsNullOrWhiteSpace(SearchText) ||
                (t.Title != null && t.Title.Contains(SearchText, StringComparison.OrdinalIgnoreCase)) ||
                (t.TrackArtist != null && t.TrackArtist.Contains(SearchText, StringComparison.OrdinalIgnoreCase)) ||
                (t.UploaderName != null && t.UploaderName.Contains(SearchText, StringComparison.OrdinalIgnoreCase))) &&
                (SelectedGenre == "Alle" || t.TrackGenre == SelectedGenre)
            ).ToList();
        }

        if (allPlaylists != null)
        {
            filteredPlaylists = allPlaylists.Where(p =>
                (string.IsNullOrWhiteSpace(SearchText) ||
                (p.PlaylistName != null && p.PlaylistName.Contains(SearchText, StringComparison.OrdinalIgnoreCase))) &&
                (SelectedGenre == "Alle" || p.PlaylistGenre == SelectedGenre)
            ).ToList();
        }
    }

    private void OpenTrackDetails(TrackModel track)
    {
        selectedTrack = track;
        selectedPlaylist = null;
        actionMessage = "";
        StateHasChanged();
    }

    private async Task OpenPlaylistDetails(Playlistmodel item)
    {
        selectedPlaylist = item;
        selectedTrack = null;
        actionMessage = "";

        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var playlistTracks = await client.GetFromJsonAsync<List<PlaylistTrackModel>>($"playlists/{item.PlaylistId}/tracks");
            if (playlistTracks != null)
            {
                selectedPlaylist.Tracks = playlistTracks;
            }
        }
        catch (Exception) { }

        StateHasChanged();
    }

    private void CloseDetails()
    {
        selectedTrack = null;
        selectedPlaylist = null;
        actionMessage = "";
        StateHasChanged();
    }

    // Gekoppeld aan je nieuwe DELETE endpoint
    private async Task DeleteUploadedTrack()
    {
        if (selectedTrack == null) return;
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.DeleteAsync($"/tracks/{selectedTrack.TrackId}");

            if (response.IsSuccessStatusCode)
            {
                actionMessage = "🗑️ Permanent verwijderd van de server!";
                await LoadMusicData(); // Herlaad de wereldwijde lijst direct
                await Task.Delay(1000);
                CloseDetails();
            }
            else
            {
                actionMessage = "❌ Verwijderen mislukt.";
            }
        }
        catch { actionMessage = "❌ Fout bij verbinden met API."; }
    }

    // --- API ACTIES (Liken in Discover.razor) ---
    private async Task LikeTrack(int trackId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");

            // Matches exact met je backend URL: /users/{userId}/likes/tracks/{trackId}
            var response = await client.PostAsync($"users/{Userstate.UserID}/likes/tracks/{trackId}", null);

            if (response.IsSuccessStatusCode)
            {
                actionMessage = "❤️ Track toegevoegd aan je favorieten!";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                actionMessage = "📢 Je had deze track al geliket!";
            }
            else
            {
                actionMessage = "⚠️ Kon track niet liken.";
            }
        }
        catch (Exception ex)
        {
            actionMessage = "❌ Fout bij verbinden met server.";
            Console.WriteLine($"Like error: {ex.Message}");
        }

        StateHasChanged(); // Dwing de UI om de actionMessage direct te tonen!
    }

    private async Task LikePlaylist(int playlistId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");

            // Let op: we matchen hier de typo uit je backend ("playlist/{playlisId}")
            // en sturen de playlistId mee naar de parameter die daar 'trackId' heet.
            var response = await client.PostAsync($"users/{Userstate.UserID}/likes/playlist/{playlistId}", null);

            if (response.IsSuccessStatusCode)
            {
                actionMessage = "❤️ Playlist opgeslagen in je kluis!";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                actionMessage = "📢 Je volgt deze playlist al!";
            }
            else
            {
                actionMessage = "⚠️ Kon playlist niet volgen.";
            }
        }
        catch (Exception ex)
        {
            actionMessage = "❌ Fout bij verbinden met server.";
            Console.WriteLine($"Playlist like error: {ex.Message}");
        }

        StateHasChanged();
    }

    private void PlayTrack(TrackModel track)
    {
        if (track != null && !string.IsNullOrEmpty(track.TrackFileUrl))
            AudioState.PlayTrack(track.Title ?? "Onbekende Track", track.TrackFileUrl);
    }

    private void PlayPlaylistTrack(PlaylistTrackModel track)
    {
        if (track != null && !string.IsNullOrEmpty(track.TrackFileUrl))
            AudioState.PlayTrack(track.Title ?? "Onbekende Track", track.TrackFileUrl);
    }

    private void PlayPlaylist(Playlistmodel playlist)
    {
        if (playlist.Tracks != null && playlist.Tracks.Any())
        {
            var firstTrack = playlist.Tracks.First();
            PlayPlaylistTrack(firstTrack);
        }
    }

    // --- DTO Classes (Nu met de felbegeerde TrackArtist!) ---
    public class TrackModel
    {
        public int TrackId { get; set; }
        public string? Title { get; set; }
        public string? TrackArtist { get; set; } // Zorg dat deze exact zo heet
        public double? DurationMs { get; set; }
        public string? TrackGenre { get; set; }  // Zorg dat deze exact zo heet
        public string? UploaderName { get; set; }
        public string? TrackFileUrl { get; set; } // Dit moet exact matchen met de API!
    }
    public class PlaylistTrackModel { public int? Position { get; set; } public int TrackId { get; set; } public string? Title { get; set; } public double? Duration { get; set; } public string? TrackFileUrl { get; set; } }
    public class Playlistmodel { public int PlaylistId { get; set; } public string? PlaylistName { get; set; } public string? PlaylistDescription { get; set; } public string? PlaylistGenre { get; set; } public string? PlaylistTags { get; set; } public List<PlaylistTrackModel> Tracks { get; set; } = new(); }
}