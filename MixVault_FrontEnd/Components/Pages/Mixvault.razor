@page "/MixVault/{userId:int}"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@inject IHttpClientFactory HttpClientFactory
@inject MixVault_FrontEnd.Services.AudioState AudioState
@inject MixVault_FrontEnd.Services.Userstate Userstate
@inject NavigationManager NavigationManager
@inject ProtectedLocalStorage ProtectedLocalStore

<PageTitle>Mijn MixVault</PageTitle>

<style>
    html, body {
        max-width: 100vw;
        overflow-x: hidden;
    }

    .container-fluid {
        max-width: 100vw;
        overflow-x: visible !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
    }

    .horizontal-scroll-wrapper {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: nowrap !important;
        overflow-x: auto !important;
        overflow-y: hidden !important;
        width: 100% !important;
        max-width: 100% !important;
        gap: 1.5rem;
        padding-top: 10px;
        padding-bottom: 25px;
        padding-left: 2rem !important;
        padding-right: 3rem !important;
        scrollbar-width: thin !important;
        scrollbar-color: var(--accent-pink) #1e1e24 !important;
        -webkit-overflow-scrolling: touch;
        box-sizing: border-box !important;
    }

        .horizontal-scroll-wrapper::-webkit-scrollbar {
            height: 8px !important;
            display: block !important;
        }

        .horizontal-scroll-wrapper::-webkit-scrollbar-track {
            background: #1e1e24 !important;
            border-radius: 10px;
        }

        .horizontal-scroll-wrapper::-webkit-scrollbar-thumb {
            background-color: var(--accent-pink) !important;
            border-radius: 10px;
            cursor: pointer;
        }

        .horizontal-scroll-wrapper::after {
            content: "";
            flex: 0 0 1px;
            padding-right: 3rem;
        }

    .scroll-card {
        display: block !important;
        flex: 0 0 260px !important;
        width: 260px !important;
        min-width: 260px !important;
        box-sizing: border-box !important;
        cursor: pointer;
    }

    .section-title {
        font-weight: 800;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        padding-left: 2rem;
        color: var(--text-white);
    }
</style>

@if (isCheckingLogin)
{
    <div class="container-fluid mt-4 px-4 text-white"><h4>Sessie herstellen... een moment geduld.</h4></div>
}
else
{
    <div class="container-fluid mt-4 px-4 text-white">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="fw-bold m-0" style="padding-left: 2rem;">Welkom terug, @Userstate.DisplayName</h1>

            <div style="width: 300px; padding-right: 2rem;">
                <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="🔍 Zoek in je kluis..." @bind="SearchText" @bind:event="oninput" style="border-radius: 8px;" />
            </div>
        </div>

        @* --- RIJ 1: JOUW EIGEN UPLOADS --- *@
        <h3 class="section-title">☁️ Mijn Uploads</h3>
        @if (filteredMyUploads == null)
        {
            <p class="text-muted ms-4"><em>Uploads laden...</em></p>
        }
        else if (filteredMyUploads.Count == 0)
        {

            <p class="text-muted ms-4">Je hebt nog geen eigen nummers geüpload.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var track in filteredMyUploads)
                {
                    <div class="mv-card scroll-card p-3" @onclick="() => OpenTrackDetails(track)">
                        <h5 class="fw-bold text-truncate text-white mb-1">@track.Title</h5>
                        <p class="small mb-2" style="color: var(--text-soft);">👤 @(string.IsNullOrEmpty(track.TrackArtist) ? track.UploaderName : track.TrackArtist)</p>
                        <span class="badge rgba-pink-bg" style="color: var(--accent-pink); border: 1px solid var(--accent-pink);">@track.TrackGenre</span>
                    </div>
                }
            </div>
        }

        @* --- RIJ 2: JOUW EIGEN PLAYLISTS --- *@
        <h3 class="section-title">🛠️ Mijn Gemaakte Playlists</h3>
        @if (filteredMyPlaylists == null)
        {
            <p class="text-muted ms-4"><em>Playlists laden...</em></p>
        }
        else if (filteredMyPlaylists.Count == 0)
        {

            <p class="text-muted ms-4">Je hebt nog geen eigen playlists gebouwd.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var playlist in filteredMyPlaylists)
                {
                    <div class="mv-card scroll-card p-3" @onclick="() => OpenPlaylistDetails(playlist)">
                        <h5 class="fw-bold text-truncate text-white mb-1">@playlist.PlaylistName</h5>
                        <p class="small mb-2" style="color: var(--text-soft);">Genre: @playlist.PlaylistGenre</p>
                        <span class="badge bg-secondary">Eigen Lijst</span>
                    </div>
                }
            </div>
        }

        @* --- RIJ 3: GELIKETE NUMMERS --- *@
        <h3 class="section-title">❤️ Jouw Favorieten</h3>
        @if (filteredLikedTracks == null)
        {
            <p class="text-muted ms-4"><em>Nummers laden...</em></p>
        }
        else if (filteredLikedTracks.Count == 0)
        {

            <p class="text-muted ms-4">Geen favoriete nummers gevonden.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var track in filteredLikedTracks)
                {
                    <div class="mv-card scroll-card p-3" @onclick="() => OpenTrackDetails(track)">
                        <h5 class="fw-bold text-truncate text-white mb-1">@track.Title</h5>
                        <p class="small mb-2" style="color: var(--text-soft);">👤 @(string.IsNullOrEmpty(track.TrackArtist) ? track.UploaderName : track.TrackArtist)</p>
                        <span class="badge rgba-pink-bg" style="color: var(--accent-pink); border: 1px solid var(--accent-pink);">@track.TrackGenre</span>
                    </div>
                }
            </div>
        }

        @* --- RIJ 4: OPGESLAGEN PLAYLISTS VAN ANDEREN --- *@
        <h3 class="section-title">📂 Gevolgde Playlists</h3>
        @if (filteredLikedPlaylists == null)
        {
            <p class="text-muted ms-4"><em>Playlists laden...</em></p>
        }
        else if (filteredLikedPlaylists.Count == 0)
        {

            <p class="text-muted ms-4">Geen gevolgde playlists gevonden.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var item in filteredLikedPlaylists)
                {
                    <div class="mv-card scroll-card p-3" @onclick="() => OpenPlaylistDetails(item)">
                        <h5 class="fw-bold text-truncate text-white mb-1">@item.PlaylistName</h5>
                        <p class="small mb-2" style="color: var(--text-soft);">Genre: @item.PlaylistGenre</p>
                        <span class="badge bg-info text-dark">Publieke Lijst</span>
                    </div>
                }
            </div>
        }
    </div>

    @* ========================================================== *@
    @* --- UNIVERSELE UNIFORME MODAL: TRACK INFO --- *@
    @* ========================================================== *@
    @if (selectedTrack != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="background-color: var(--bg-card); border: 1px solid var(--accent-pink); color: white;">
                    <div class="modal-header border-0">
                        <h5 class="modal-title fw-bold">Track Details</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CloseDetails"></button>
                    </div>

                    <div class="modal-body text-center py-4">
                        <h2 class="fw-bold text-white mb-1">@selectedTrack.Title</h2>
                        <h4 class="mb-4" style="color: var(--accent-pink);">
                            👤 @(string.IsNullOrEmpty(selectedTrack.TrackArtist) ? selectedTrack.UploaderName : selectedTrack.TrackArtist)
                        </h4>

                        @if (!showPlaylistSelector)
                        {
                            <p class="text-muted small">Gemixt/Geüpload door: @selectedTrack.UploaderName</p>
                            <div class="d-flex justify-content-center gap-2 mt-3">
                                <span class="badge bg-dark border border-secondary p-2">Genre: @selectedTrack.TrackGenre</span>
                                <span class="badge bg-dark border border-secondary p-2">
                                    ⏳ @(selectedTrack.DurationMs.HasValue? Math.Round(selectedTrack.DurationMs.Value / 60000, 2).ToString("0.00") : "Onbekend") min
                                </span>
                            </div>
                        }
                        else
                        {
                            @* --- PLAYLIST SELECTOR WEERGAVE IN DE MODAL --- *@
                            <div class="playlist-selector-view mt-3 text-start">
                                <h5 class="mb-3 border-bottom pb-2" style="border-color: rgba(255,255,255,0.1) !important;">Kies een Playlist</h5>
                                <div style="max-height: 150px; overflow-y: auto;" class="mb-3">
                                    @if (myPlaylists != null && myPlaylists.Any())
                                    {
                                        @foreach (var p in myPlaylists)
                                        {
                                            <button class="btn btn-outline-secondary w-100 mb-2 text-start text-white" @onclick="() => AddTrackToExistingPlaylist(p.PlaylistId)">
                                                📁 @p.PlaylistName
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted small">Je hebt nog geen eigen playlists.</p>
                                    }
                                </div>
                                <h5 class="mb-2">Of maak een nieuwe:</h5>
                                <div class="input-group mb-2">
                                    <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Naam nieuwe playlist..." @bind="newPlaylistName" />
                                    <button class="btn btn-mv-accent" @onclick="CreatePlaylistAndAddTrack">Maken</button>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(actionMessage))
                        {
                            <div class="mt-3 small text-info fw-bold">✨ @actionMessage</div>
                        }
                    </div>

                    <div class="modal-footer border-0 d-flex flex-column gap-2">
                        @if (!showPlaylistSelector)
                        {
                            <button class="btn btn-mv-accent w-100 py-2 fw-bold" @onclick="() => PlayTrack(selectedTrack)">▶ NU AFSPELEN</button>

                            @if (selectedTrack.UploaderName == Userstate.DisplayName)
                            {
                                <button class="btn btn-danger w-100 py-2 fw-bold" @onclick="DeleteUploadedTrack">🗑️ VERWIJDEREN VAN SERVER</button>
                            }

                            <div class="d-flex gap-2 w-100 mt-2">
                                @* DYNAMISCHE LIKE / DISLIKE KNOP *@
                                @if (userLikedTrackIds.Contains(selectedTrack.TrackId))
                                {
                                    <button class="btn btn-outline-danger flex-grow-1" @onclick="() => UnlikeTrack(selectedTrack.TrackId)">💔 Dislike</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-light flex-grow-1" @onclick="() => LikeTrack(selectedTrack.TrackId)">❤️ Liken</button>
                                }

                                <button class="btn btn-outline-info flex-grow-1" @onclick="OpenPlaylistSelector">➕ Playlist</button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-link text-muted w-100 text-decoration-none" @onclick="() => { showPlaylistSelector = false; actionMessage = string.Empty; }">
                                ⬅ Terug naar Track Info
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* ========================================================== *@
    @* --- UNIVERSELE UNIFORME MODAL: PLAYLIST INFO --- *@
    @* ========================================================== *@
    @if (selectedPlaylist != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content" style="background-color: var(--bg-card); border: 1px solid var(--accent-pink); color: white;">
                    <div class="modal-header border-0">
                        <h5 class="modal-title fw-bold">Playlist Info</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CloseDetails"></button>
                    </div>
                    <div class="modal-body">
                        <h3 class="fw-bold text-white mb-1">@selectedPlaylist.PlaylistName</h3>
                        <p style="color: var(--text-soft);">@selectedPlaylist.PlaylistDescription</p>
                        <span class="badge rgba-pink-bg mb-3" style="color: var(--accent-pink);">Genre: @selectedPlaylist.PlaylistGenre</span>

                        <hr style="border-color: rgba(255,255,255,0.1);" />
                        <h5 class="fw-bold mb-3">Tracks in deze lijst</h5>

                        <div style="max-height: 250px; overflow-y: auto;">
                            @if (selectedPlaylist.Tracks != null && selectedPlaylist.Tracks.Any())
                            {
                                <div class="list-group list-group-flush">
                                    @foreach (var track in selectedPlaylist.Tracks)
                                    {
                                        <div class="list-group-item bg-transparent text-white d-flex justify-content-between align-items-center border-secondary px-0">
                                            <div>
                                                <strong class="text-white">@(track.Position). @track.Title</strong><br />
                                                <small style="color: var(--text-soft);">⏳ @(track.Duration.HasValue? Math.Round(track.Duration.Value / 60000, 2).ToString("0.00") : "Onbekend") min</small>
                                            </div>
                                            <div class="d-flex gap-2">
                                                @* Verwijder track uit playlist (alleen als jij eigenaar bent) *@
                                                @if (myPlaylists != null && myPlaylists.Any(p => p.PlaylistId == selectedPlaylist.PlaylistId))
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" title="Verwijder uit playlist" @onclick="() => RemoveTrackFromPlaylist(selectedPlaylist.PlaylistId, track.TrackId)">❌</button>
                                                }
                                                <button class="btn btn-sm btn-mv-accent" title="Speel af" @onclick="() => PlayPlaylistTrack(track)">▶</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {

                                <p class="text-muted small">Deze lijst bevat nog geen nummers.</p>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(actionMessage))
                        {
                            <div class="mt-2 small text-info fw-bold text-center">✨ @actionMessage</div>
                        }
                    </div>

                    <div class="modal-footer border-0 justify-content-center gap-2">
                        <button class="btn btn-mv-accent btn-lg px-4 fw-bold" @onclick="async () => await PlayPlaylist(selectedPlaylist)">
                            ▶ Alles Afspelen
                        </button>

                        @* DYNAMISCHE KNOP: Eigenaar (Delete) VS Volgen (Like/Dislike) *@
                        @if (myPlaylists != null && myPlaylists.Any(p => p.PlaylistId == selectedPlaylist.PlaylistId))
                        {
                            <button class="btn btn-danger btn-lg px-4" @onclick="DeleteOwnPlaylist">
                                🗑️ Verwijder Playlist
                            </button>
                        }
                        else
                        {
                            @if (userLikedPlaylistIds.Contains(selectedPlaylist.PlaylistId))
                            {
                                <button class="btn btn-outline-danger btn-lg px-4" @onclick="() => UnlikePlaylist(selectedPlaylist.PlaylistId)">
                                    💔 Ontvolgen
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-outline-light btn-lg px-4" @onclick="() => LikePlaylist(selectedPlaylist.PlaylistId)">
                                    ❤️ Playlist Volgen
                                </button>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int userId { get; set; }
    private bool isCheckingLogin = true;
    private string actionMessage = "";

    // Data lijsten vanuit API
    private List<TrackModel>? likedTracks;
    private List<Playlistmodel>? likedPlaylists;
    private List<TrackModel>? myUploads;
    private List<Playlistmodel>? myPlaylists;

    // Gefilterde lijsten voor UI
    private List<TrackModel>? filteredLikedTracks;
    private List<Playlistmodel>? filteredLikedPlaylists;
    private List<TrackModel>? filteredMyUploads;
    private List<Playlistmodel>? filteredMyPlaylists;

    // Like state IDs voor de UI
    private List<int> userLikedTrackIds = new();
    private List<int> userLikedPlaylistIds = new();

    // Playlist Selector in Track Modal
    private bool showPlaylistSelector = false;
    private string newPlaylistName = "";

    // Zoeken
    private string _searchText = "";
    private string SearchText { get => _searchText; set { _searchText = value; ApplySearchFilter(); } }

    private TrackModel? selectedTrack;
    private Playlistmodel? selectedPlaylist;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                if (!Userstate.IsLoggedIn)
                {
                    var storedUserId = await ProtectedLocalStore.GetAsync<int>("userId");
                    var storedUserName = await ProtectedLocalStore.GetAsync<string>("userName");
                    if (storedUserId.Success && storedUserName.Success)
                        Userstate.LogIn(storedUserId.Value, storedUserName.Value);
                    else
                    {
                        NavigationManager.NavigateTo("/");
                        return;
                    }
                }

                if (userId != Userstate.UserID)
                {
                    NavigationManager.NavigateTo($"/MixVault/{Userstate.UserID}");
                    return;
                }

                await LoadDashboardData();
            }
            catch (Exception)
            {
                NavigationManager.NavigateTo("/");
                return;
            }
            finally
            {
                isCheckingLogin = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadDashboardData()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");

            // Haal de data op
            likedTracks = await client.GetFromJsonAsync<List<TrackModel>>($"users/{userId}/likes/tracks");
            likedPlaylists = await client.GetFromJsonAsync<List<Playlistmodel>>($"users/{userId}/likes/playlists");
            myPlaylists = await client.GetFromJsonAsync<List<Playlistmodel>>($"users/{userId}/playlists");

            var allWorldTracks = await client.GetFromJsonAsync<List<TrackModel>>("tracks");
            if (allWorldTracks != null) myUploads = allWorldTracks.Where(t => t.UploaderName == Userstate.DisplayName).ToList();

            // Vul de lijsten voor de Like/Dislike checks!
            if (likedTracks != null) userLikedTrackIds = likedTracks.Select(t => t.TrackId).ToList();
            if (likedPlaylists != null) userLikedPlaylistIds = likedPlaylists.Select(p => p.PlaylistId).ToList();

            ApplySearchFilter();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fout bij inladen data: {ex.Message}");
            likedTracks = new(); likedPlaylists = new(); myUploads = new(); myPlaylists = new();
            ApplySearchFilter();
        }
    }

    private void ApplySearchFilter()
    {
        if (likedTracks != null) filteredLikedTracks = likedTracks.Where(t => string.IsNullOrWhiteSpace(SearchText) || (t.Title != null && t.Title.Contains(SearchText, StringComparison.OrdinalIgnoreCase)) || (t.TrackArtist != null && t.TrackArtist.Contains(SearchText, StringComparison.OrdinalIgnoreCase))).ToList();
        if (likedPlaylists != null) filteredLikedPlaylists = likedPlaylists.Where(p => string.IsNullOrWhiteSpace(SearchText) || (p.PlaylistName != null && p.PlaylistName.Contains(SearchText, StringComparison.OrdinalIgnoreCase))).ToList();
        if (myUploads != null) filteredMyUploads = myUploads.Where(t => string.IsNullOrWhiteSpace(SearchText) || (t.Title != null && t.Title.Contains(SearchText, StringComparison.OrdinalIgnoreCase)) || (t.TrackArtist != null && t.TrackArtist.Contains(SearchText, StringComparison.OrdinalIgnoreCase))).ToList();
        if (myPlaylists != null) filteredMyPlaylists = myPlaylists.Where(p => string.IsNullOrWhiteSpace(SearchText) || (p.PlaylistName != null && p.PlaylistName.Contains(SearchText, StringComparison.OrdinalIgnoreCase))).ToList();
    }

    // --- MODAL CONTROLS ---
    private void OpenTrackDetails(TrackModel track)
    {
        selectedTrack = track;
        selectedPlaylist = null;
        actionMessage = "";
        showPlaylistSelector = false;
        StateHasChanged();
    }

    private async Task OpenPlaylistDetails(Playlistmodel item)
    {
        selectedPlaylist = item;
        selectedTrack = null;
        actionMessage = "";
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var playlistTracks = await client.GetFromJsonAsync<List<PlaylistTrackModel>>($"playlists/{item.PlaylistId}/tracks");
            if (playlistTracks != null) selectedPlaylist.Tracks = playlistTracks;
        }
        catch (Exception) { }
        StateHasChanged();
    }

    private void CloseDetails()
    {
        selectedTrack = null;
        selectedPlaylist = null;
        actionMessage = "";
        showPlaylistSelector = false;
        StateHasChanged();
    }

    // --- DELETE / REMOVE ACTIES ---
    private async Task DeleteUploadedTrack()
    {
        if (selectedTrack == null) return;
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.DeleteAsync($"/tracks/{selectedTrack.TrackId}");
            if (response.IsSuccessStatusCode)
            {
                actionMessage = "🗑️ Track permanent verwijderd van server!";
                await LoadDashboardData();
                await Task.Delay(1000);
                CloseDetails();
            }
            else actionMessage = "❌ Verwijderen mislukt.";
        }
        catch { actionMessage = "❌ Fout bij verbinden met API."; }
    }

    private async Task DeleteOwnPlaylist()
    {
        if (selectedPlaylist == null) return;
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.DeleteAsync($"/playlists/{selectedPlaylist.PlaylistId}");
            if (response.IsSuccessStatusCode)
            {
                actionMessage = "🗑️ Playlist definitief verwijderd!";
                await LoadDashboardData();
                await Task.Delay(1000);
                CloseDetails();
            }
            else actionMessage = "❌ Fout bij verwijderen playlist.";
        }
        catch { actionMessage = "❌ Fout bij verbinden met API."; }
    }

    private async Task RemoveTrackFromPlaylist(int playlistId, int trackId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.DeleteAsync($"/playlists/{playlistId}/tracks/{trackId}");
            if (response.IsSuccessStatusCode)
            {
                if (selectedPlaylist?.Tracks != null) selectedPlaylist.Tracks.RemoveAll(t => t.TrackId == trackId);
                actionMessage = "✅ Track uit playlist verwijderd.";
                StateHasChanged();
            }
            else actionMessage = "❌ Fout bij verwijderen track.";
        }
        catch { actionMessage = "❌ Fout bij API."; }
    }

    // --- LIKEN EN ONTVOLGEN ---
    private async Task LikeTrack(int trackId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.PostAsync($"users/{Userstate.UserID}/likes/tracks/{trackId}", new StringContent(""));
            if (response.IsSuccessStatusCode || response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                actionMessage = "❤️ Track toegevoegd aan je favorieten!";
                if (!userLikedTrackIds.Contains(trackId)) userLikedTrackIds.Add(trackId);
            }
            else actionMessage = "⚠️ Kon track niet liken.";
        }
        catch { actionMessage = "❌ Fout bij server."; }
        StateHasChanged();
    }

    private async Task UnlikeTrack(int trackId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.DeleteAsync($"users/{Userstate.UserID}/likes/tracks/{trackId}");
            if (response.IsSuccessStatusCode)
            {
                actionMessage = "💔 Verwijderd uit je likes.";
                userLikedTrackIds.Remove(trackId);
                // Herlaad de data direct zodat hij ook uit het grid "Jouw Favorieten" verdwijnt!
                await LoadDashboardData();
            }
            else actionMessage = "⚠️ Kon track niet disliken.";
        }
        catch { actionMessage = "❌ Fout bij server."; }
        StateHasChanged();
    }

    private async Task LikePlaylist(int playlistId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.PostAsync($"users/{Userstate.UserID}/likes/playlist/{playlistId}", new StringContent(""));
            if (response.IsSuccessStatusCode)
            {
                actionMessage = "❤️ Playlist opgeslagen!";
                if (!userLikedPlaylistIds.Contains(playlistId)) userLikedPlaylistIds.Add(playlistId);
                await LoadDashboardData();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict) actionMessage = "📢 Je volgt deze playlist al!";
            else actionMessage = "⚠️ Mislukt.";
        }
        catch { actionMessage = "❌ Fout."; }
        StateHasChanged();
    }

    private async Task UnlikePlaylist(int playlistId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.DeleteAsync($"users/{Userstate.UserID}/likes/playlist/{playlistId}");
            if (response.IsSuccessStatusCode)
            {
                actionMessage = "💔 Playlist ontvolgd.";
                userLikedPlaylistIds.Remove(playlistId);
                await LoadDashboardData();
            }
            else actionMessage = "⚠️ Kon playlist niet ontvolgen.";
        }
        catch { actionMessage = "❌ Fout bij server."; }
        StateHasChanged();
    }

    // --- PLAYLIST SELECTOR LOGICA ---
    private void OpenPlaylistSelector() { showPlaylistSelector = true; actionMessage = ""; }

    private async Task AddTrackToExistingPlaylist(int playlistId)
    {
        if (selectedTrack == null) return;
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var response = await client.PostAsync($"playlists/{playlistId}/tracks/{selectedTrack.TrackId}", new StringContent(""));
            if (response.IsSuccessStatusCode)
            {
                actionMessage = "✅ Succesvol toegevoegd aan de playlist!";
                StateHasChanged();
                await Task.Delay(1500);
                showPlaylistSelector = false;
            }
            else actionMessage = "⚠️ Kon track niet toevoegen.";
        }
        catch { actionMessage = "❌ Fout bij verbinden."; }
        StateHasChanged();
    }

    private async Task CreatePlaylistAndAddTrack()
    {
        if (string.IsNullOrWhiteSpace(newPlaylistName) || selectedTrack == null)
        {
            actionMessage = "Vul een naam in voor de playlist!"; return;
        }
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var newPlaylist = new Playlistmodel { PlaylistName = newPlaylistName, PlaylistDescription = "Nieuwe playlist", PlaylistGenre = selectedTrack.TrackGenre };
            var createResponse = await client.PostAsJsonAsync($"users/{Userstate.UserID}/playlists", newPlaylist);
            if (createResponse.IsSuccessStatusCode)
            {
                var createdPlaylist = await createResponse.Content.ReadFromJsonAsync<Playlistmodel>();
                if (createdPlaylist != null)
                {
                    await AddTrackToExistingPlaylist(createdPlaylist.PlaylistId);
                    await LoadDashboardData();
                    newPlaylistName = "";
                }
            }
            else actionMessage = "⚠️ Kon playlist niet aanmaken.";
        }
        catch { actionMessage = "❌ Fout bij verbinden."; }
        StateHasChanged();
    }

    // --- AUDIO PLAYERS ---
    private void PlayTrack(TrackModel track) { if (track != null && !string.IsNullOrEmpty(track.TrackFileUrl)) AudioState.PlayTrack(track.Title ?? "Onbekende Track", track.TrackFileUrl); }
    private void PlayPlaylistTrack(PlaylistTrackModel track) { if (track != null && !string.IsNullOrEmpty(track.TrackFileUrl)) AudioState.PlayTrack(track.Title ?? "Onbekende Track", track.TrackFileUrl); }
    private async Task PlayPlaylist(Playlistmodel playlist)
    {
        if (playlist.Tracks == null || !playlist.Tracks.Any())
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var playlistTracks = await client.GetFromJsonAsync<List<PlaylistTrackModel>>($"playlists/{playlist.PlaylistId}/tracks");
            if (playlistTracks != null && playlistTracks.Any()) PlayPlaylistTrack(playlistTracks.First());
        }
        else PlayPlaylistTrack(playlist.Tracks.First());
    }

    // --- DTO Classes ---
    public class TrackModel { public int TrackId { get; set; } public string? Title { get; set; } public string? TrackArtist { get; set; } public double? DurationMs { get; set; } public string? TrackGenre { get; set; } public string? UploaderName { get; set; } public string? TrackFileUrl { get; set; } }
    public class PlaylistTrackModel { public int? Position { get; set; } public int TrackId { get; set; } public string? Title { get; set; } public double? Duration { get; set; } public string? TrackFileUrl { get; set; } }
    public class Playlistmodel { public int PlaylistId { get; set; } public string? PlaylistName { get; set; } public string? PlaylistDescription { get; set; } public string? PlaylistGenre { get; set; } public string? PlaylistTags { get; set; } public List<PlaylistTrackModel> Tracks { get; set; } = new(); }
}