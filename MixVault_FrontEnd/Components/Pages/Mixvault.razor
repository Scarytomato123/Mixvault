@page "/MixVault/{userId:int}"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@inject IHttpClientFactory HttpClientFactory
@inject MixVault_FrontEnd.Services.AudioState AudioState
@inject MixVault_FrontEnd.Services.Userstate Userstate
@inject NavigationManager NavigationManager
@inject ProtectedLocalStorage ProtectedLocalStore

<PageTitle>Mijn MixVault</PageTitle>

<style>
    .horizontal-scroll-wrapper {
        display: flex;
        overflow-x: auto;
        gap: 1.5rem;
        padding-bottom: 15px;
        scrollbar-width: thin;
        /* Gebruik hier onze globale roze kleur voor de scrollbar */
        scrollbar-color: var(--accent-pink) #222;
    }

    .scroll-card {
        flex: 0 0 260px;
        cursor: pointer;
        transition: transform 0.2s, border-color 0.2s;
    }

    /* We gebruiken hier de mv-card klasse uit app.css */
    .section-title {
        font-weight: 800;
        margin-top: 2rem;
        margin-bottom: 1rem;
        color: var(--text-white);
    }
</style>

@if (isCheckingLogin)
{
    <div class="container-fluid mt-4 px-4 text-white">
        <h4>Sessie herstellen... een moment geduld.</h4>
    </div>
}
else
{
    <div class="container-fluid mt-4 px-4 text-white">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="fw-bold m-0">Welkom terug, @Userstate.DisplayName</h1>

            @* --- ZOEKEN BINNEN JE KLUIS --- *@
            <div style="width: 300px;">
                <input type="text" class="form-control bg-dark text-white border-secondary"
                       placeholder="🔍 Zoek in je kluis..."
                       @bind="SearchText" @bind:event="oninput" />
            </div>
        </div>

        @* --- RIJ 1: JOUW UPLOADS --- *@
        <h3 class="section-title">☁️ Mijn Uploads</h3>
        @if (filteredMyUploads == null)
        {
            <p class="text-muted"><em>Uploads laden...</em></p>
        }
        else if (filteredMyUploads.Count == 0)
        {
            <p class="text-muted">Je hebt nog geen eigen nummers geüpload of gevonden.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var track in filteredMyUploads)
                {
                    @* mv-card geeft de paarse achtergrond, scroll-card zorgt voor de vorm *@
                    <div class="mv-card scroll-card p-3" @onclick="() => PlayTrack(track)">
                        <h5 class="fw-bold">@track.Title</h5>
                        <p class="text-muted">@track.UploaderName</p>
                    </div>
                }
            </div>
        }

        @* --- RIJ 2: GELIKETE NUMMERS --- *@
        <h3 class="section-title">❤️ Jouw Favorieten</h3>
        @if (filteredLikedTracks == null)
        {
            <p class="text-muted"><em>Nummers laden...</em></p>
        }
        else if (filteredLikedTracks.Count == 0)
        {
            <p class="text-muted">Geen favoriete nummers gevonden.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var track in filteredLikedTracks)
                {
                    <div class="card shadow-sm bg-dark text-white border-secondary scroll-card" @onclick="() => OpenTrackDetails(track)">
                        <div class="card-body">
                            <h5 class="card-title text-truncate">@track.Title</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@track.UploaderName</h6>
                            <span class="badge bg-secondary">@track.TrackGenre</span>
                            <div class="mt-3">
                                <button class="btn btn-outline-success btn-sm w-100" @onclick:stopPropagation="true" @onclick="() => PlayTrack(track)">
                                    ▶ Afspelen
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @* --- RIJ 3: JOUW PLAYLISTS --- *@
        <h3 class="section-title">📂 Opgeslagen Playlists</h3>
        @if (filteredLikedPlaylists == null)
        {
            <p class="text-muted"><em>Playlists laden...</em></p>
        }
        else if (filteredLikedPlaylists.Count == 0)
        {
            <p class="text-muted">Geen playlists gevonden.</p>
        }
        else
        {
            <div class="horizontal-scroll-wrapper">
                @foreach (var item in filteredLikedPlaylists)
                {
                    <div class="card shadow-sm bg-dark text-white border-info scroll-card" @onclick="() => OpenPlaylistDetails(item)">
                        <div class="card-body">
                            <h5 class="card-title text-truncate">@item.PlaylistName</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@item.PlaylistGenre</h6>
                            <span class="badge bg-info text-dark">@item.PlaylistTags</span>
                            <div class="mt-3">
                                <button class="btn btn-outline-info btn-sm w-100" @onclick:stopPropagation="true" @onclick="async () => await PlayPlaylist(item)">
                                    ▶ Afspelen
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* --- MODALS (Exact dezelfde stijl als Discover) --- *@
    @if (selectedTrack != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.8);">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content bg-dark text-white border-success">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title text-success">Track Info</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CloseDetails"></button>
                    </div>
                    <div class="modal-body text-center py-5">
                        <h2 class="fw-bold">@selectedTrack.Title</h2>
                        <h4 class="text-muted mb-4">Gemixt door: @selectedTrack.UploaderName</h4>
                        <div class="d-flex justify-content-center gap-3 mb-4">
                            <span class="badge bg-secondary fs-6 p-2">Genre: @selectedTrack.TrackGenre</span>
                            <span class="badge bg-secondary fs-6 p-2">Duur: @(selectedTrack.DurationMs.HasValue? Math.Round(selectedTrack.DurationMs.Value / 60000, 2).ToString("0.00") : "Onbekend") min</span>
                        </div>
                    </div>
                    <div class="modal-footer border-secondary justify-content-center gap-2">
                        <button class="btn btn-success btn-lg px-4" @onclick="() => PlayTrack(selectedTrack)">▶ Afspelen</button>
                        <button class="btn btn-outline-danger btn-lg px-4" @onclick="UnlikeTrack">💔 Verwijder uit Favorieten</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (selectedPlaylist != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.8);">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content bg-dark text-white border-info">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title text-info">Playlist Info</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CloseDetails"></button>
                    </div>
                    <div class="modal-body">
                        <h3 class="fw-bold">@selectedPlaylist.PlaylistName</h3>
                        <p class="text-muted">@selectedPlaylist.PlaylistDescription</p>
                        <hr class="border-secondary" />
                        <h5>Tracks in deze lijst</h5>
                        <div class="playlist-tracks-scroll">
                            @if (selectedPlaylist.Tracks != null && selectedPlaylist.Tracks.Any())
                            {
                                <ul class="list-group list-group-flush bg-dark">
                                    @foreach (var track in selectedPlaylist.Tracks)
                                    {
                                        <li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center border-secondary">
                                            <div>
                                                <strong>@(track.Position). @track.Title</strong><br />
                                                <small class="text-muted">Duur: @(track.Duration.HasValue? Math.Round(track.Duration.Value / 60000, 2).ToString("0.00") : "Onbekend") min</small>
                                            </div>
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => PlayPlaylistTrack(track)">▶</button>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                    <div class="modal-footer border-secondary justify-content-center gap-2">
                        <button class="btn btn-info btn-lg px-4 text-dark" @onclick="async () => await PlayPlaylist(selectedPlaylist)">▶ Alles Afspelen</button>
                        <button class="btn btn-outline-danger btn-lg px-4" @onclick="UnlikePlaylist">💔 Verwijder Playlist</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int userId { get; set; }

    private bool isCheckingLogin = true;

    // Basis lijsten vanuit API
    private List<TrackModel>? likedTracks;
    private List<Playlistmodel>? likedPlaylists;
    private List<TrackModel>? myUploads;

    // Gefilterde lijsten voor UI
    private List<TrackModel>? filteredLikedTracks;
    private List<Playlistmodel>? filteredLikedPlaylists;
    private List<TrackModel>? filteredMyUploads;

    // Zoekbalk koppeling
    private string _searchText = "";
    private string SearchText
    {
        get => _searchText;
        set { _searchText = value; ApplySearchFilter(); }
    }

    private TrackModel? selectedTrack;
    private Playlistmodel? selectedPlaylist;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                if (!Userstate.IsLoggedIn)
                {
                    var storedUserId = await ProtectedLocalStore.GetAsync<int>("userId");
                    var storedUserName = await ProtectedLocalStore.GetAsync<string>("userName");

                    if (storedUserId.Success && storedUserName.Success)
                        Userstate.LogIn(storedUserId.Value, storedUserName.Value);
                    else
                    {
                        NavigationManager.NavigateTo("/");
                        return;
                    }
                }

                if (userId != Userstate.UserID)
                {
                    NavigationManager.NavigateTo($"/MixVault/{Userstate.UserID}");
                    return;
                }

                await LoadDashboardData();
            }
            catch (Exception)
            {
                NavigationManager.NavigateTo("/");
                return;
            }
            finally
            {
                isCheckingLogin = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadDashboardData()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");

            // Haal de favorieten op
            likedTracks = await client.GetFromJsonAsync<List<TrackModel>>($"users/{userId}/likes/tracks");
            likedPlaylists = await client.GetFromJsonAsync<List<Playlistmodel>>($"users/{userId}/likes/playlists");

            // Haal alle tracks ter wereld op, en filter direct op degene die JIJ hebt geüpload!
            var allWorldTracks = await client.GetFromJsonAsync<List<TrackModel>>("tracks");
            if (allWorldTracks != null)
            {
                myUploads = allWorldTracks.Where(t => t.UploaderName == Userstate.DisplayName).ToList();
            }

            // Kopieer data naar de gefilterde lijsten voor de start
            ApplySearchFilter();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fout bij inladen data: {ex.Message}");
            likedTracks = new(); likedPlaylists = new(); myUploads = new();
            ApplySearchFilter();
        }
    }

    private void ApplySearchFilter()
    {
        if (likedTracks != null)
            filteredLikedTracks = likedTracks.Where(t => string.IsNullOrWhiteSpace(SearchText) || (t.Title != null && t.Title.Contains(SearchText, StringComparison.OrdinalIgnoreCase))).ToList();

        if (likedPlaylists != null)
            filteredLikedPlaylists = likedPlaylists.Where(p => string.IsNullOrWhiteSpace(SearchText) || (p.PlaylistName != null && p.PlaylistName.Contains(SearchText, StringComparison.OrdinalIgnoreCase))).ToList();

        if (myUploads != null)
            filteredMyUploads = myUploads.Where(t => string.IsNullOrWhiteSpace(SearchText) || (t.Title != null && t.Title.Contains(SearchText, StringComparison.OrdinalIgnoreCase))).ToList();
    }

    // --- MODAL & ACTIE METHODES ---

    private void OpenTrackDetails(TrackModel track)
    {
        selectedTrack = track;
        selectedPlaylist = null;
        StateHasChanged();
    }

    private async Task OpenPlaylistDetails(Playlistmodel item)
    {
        selectedPlaylist = item;
        selectedTrack = null;
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var playlistTracks = await client.GetFromJsonAsync<List<PlaylistTrackModel>>($"playlists/{item.PlaylistId}/tracks");
            if (playlistTracks != null) selectedPlaylist.Tracks = playlistTracks;
        }
        catch (Exception) { }
        StateHasChanged();
    }

    private void CloseDetails()
    {
        selectedTrack = null;
        selectedPlaylist = null;
        StateHasChanged();
    }

    // Verwijder track uit je likes (via de DELETE API)
    private async Task UnlikeTrack()
    {
        if (selectedTrack == null) return;
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            await client.DeleteAsync($"/users/{userId}/likes/tracks/{selectedTrack.TrackId}");
            await LoadDashboardData(); // Herlaad de kluis
            CloseDetails();
        }
        catch { }
    }

    // Verwijder playlist uit je likes
    private async Task UnlikePlaylist()
    {
        if (selectedPlaylist == null) return;
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            await client.DeleteAsync($"/users/{userId}/likes/playlist/{selectedPlaylist.PlaylistId}");
            await LoadDashboardData(); // Herlaad de kluis
            CloseDetails();
        }
        catch { }
    }

    // --- AUDIO AFSPELEN ---
    private void PlayTrack(TrackModel track)
    {
        if (track != null && !string.IsNullOrEmpty(track.TrackFileUrl))
            AudioState.PlayTrack(track.Title ?? "Onbekende Track", track.TrackFileUrl);
    }

    private void PlayPlaylistTrack(PlaylistTrackModel track)
    {
        if (track != null && !string.IsNullOrEmpty(track.TrackFileUrl))
            AudioState.PlayTrack(track.Title ?? "Onbekende Track", track.TrackFileUrl);
    }

    private async Task PlayPlaylist(Playlistmodel playlist)
    {
        if (playlist.Tracks == null || !playlist.Tracks.Any())
        {
            // Als de tracks nog niet in de modal waren ingeladen, halen we ze snel op
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            var playlistTracks = await client.GetFromJsonAsync<List<PlaylistTrackModel>>($"playlists/{playlist.PlaylistId}/tracks");
            if (playlistTracks != null && playlistTracks.Any())
            {
                PlayPlaylistTrack(playlistTracks.First());
            }
        }
        else
        {
            PlayPlaylistTrack(playlist.Tracks.First());
        }
    }

    // --- DTO Classes ---
    public class TrackModel { public int TrackId { get; set; } public string? Title { get; set; } public double? DurationMs { get; set; } public string? TrackGenre { get; set; } public string? UploaderName { get; set; } public string? TrackFileUrl { get; set; } }
    public class PlaylistTrackModel { public int? Position { get; set; } public int TrackId { get; set; } public string? Title { get; set; } public double? Duration { get; set; } public string? TrackFileUrl { get; set; } }
    public class Playlistmodel { public int PlaylistId { get; set; } public string? PlaylistName { get; set; } public string? PlaylistDescription { get; set; } public string? PlaylistGenre { get; set; } public string? PlaylistTags { get; set; } public List<PlaylistTrackModel> Tracks { get; set; } = new(); }
}