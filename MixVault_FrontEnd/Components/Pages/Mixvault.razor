@page "/MixVault/{userId:int}"
@inject IHttpClientFactory HttpClientFactory
@using System.Net.Http.Json

<PageTitle>MixVault - Home</PageTitle>

<style>
    /* De container die horizontaal scrollen mogelijk maakt */
    .horizontal-scroll-wrapper {
        display: flex;
        overflow-x: auto;
        gap: 1rem;
        padding-bottom: 15px;
        /* Verbergt de scrollbar in sommige browsers voor een strakker uiterlijk */
        scrollbar-width: thin;
    }

    /* Zorgt dat de kaarten niet inkrimpen en een vaste breedte hebben */
    .scroll-card {
        flex: 0 0 250px;
    }

    .section-title {
        font-weight: 800;
        margin-top: 2rem;
        margin-bottom: 1rem;
    }
</style>

<div class="container-fluid mt-4 px-4">
    <h1 class="mb-4">Ontdek Nieuwe Muziek 🎵 (Gebruiker: @userId)</h1>

    @* --- RIJ 1: GELIKETE NUMMERS --- *@
    <h3 class="section-title">❤️ Jouw Favorieten</h3>
    @if (tracks == null)
    {
        <p><em>Nummers laden...</em></p>
    }
    else if (tracks.Count == 0)
    {
        <p>Geen gelikete nummers gevonden.</p>
    }
    else
    {
        <div class="horizontal-scroll-wrapper">
            @foreach (var track in tracks)
            {
                <div class="card shadow-sm scroll-card">
                    <div class="card-body">
                        <h5 class="card-title text-truncate">@track.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@track.UploaderName</h6>
                        <span class="badge bg-primary">@track.TrackGenre</span>
                        <div class="mt-3">
                            <button class="btn btn-outline-success btn-sm w-100">▶ Afspelen</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* --- RIJ 2: PLAYLIST --- *@
    <h3 class="section-title">📂 Jouw Playlist</h3>
    @if (Playlist == null)
    {
        <p><em>Playlist laden...</em></p>
    }
    else if (Playlist.Count == 0)
    {
        <p>Je playlist is nog leeg.</p>
    }
    else
    {
        <div class="horizontal-scroll-wrapper">
            @foreach (var item in Playlist)
            {
                <div class="card shadow-sm scroll-card border-info">
                    <div class="card-body">
                        <h5 class="card-title text-truncate">@item.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@item.UploaderName</h6>
                        <span class="badge bg-info text-dark">@item.TrackGenre</span>
                        <div class="mt-3">
                            <button class="btn btn-outline-info btn-sm w-100">▶ Afspelen</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int userId { get; set; }

    private List<TrackModel>? tracks;
    private List<TrackModel>? Playlist;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");

            // Let op: Ik heb de variabele namen hieronder aangepast zodat ze in de juiste lijst komen!
            tracks = await client.GetFromJsonAsync<List<TrackModel>>($"users/{userId}/likes/tracks");
            Playlist = await client.GetFromJsonAsync<List<TrackModel>>($"users/{userId}/likes/playlists");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fout bij het ophalen van nummers: {ex.Message}");
        }
    }

    public class TrackModel
    {
        public int TrackId { get; set; }
        public string? Title { get; set; }
        public double? DurationMs { get; set; }
        public string? TrackGenre { get; set; }
        public string? UploaderName { get; set; }
    }
}