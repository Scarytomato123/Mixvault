@page "/upload"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@inject IHttpClientFactory HttpClientFactory
@inject MixVault_FrontEnd.Services.AudioState AudioState
@inject MixVault_FrontEnd.Services.Userstate Userstate
@inject NavigationManager NavigationManager
@inject ProtectedLocalStorage ProtectedLocalStore

<PageTitle>MixVault - Discover</PageTitle>

<style>
    .section-title {
        font-weight: 800;
        margin-top: 2rem;
        margin-bottom: 1rem;
    }

    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: scale(1.02);
            cursor: pointer;
        }
</style>

@if (isCheckingLogin)
{
    <div class="container-fluid mt-4 px-4">
        <h4>Sessie herstellen... een moment geduld.</h4>
    </div>
}
else
{
    <div class="container-fluid mt-4 px-4">
        <h1 class="mb-4">Ontdek Nieuwe Muziek</h1>

        @* --- SECTIE 1: ALLE TRACKS --- *@
        <h3 class="section-title">🌍 Wereldwijde Tracks</h3>
        @if (allTracks == null)
        {
            <p><em>Tracks laden...</em></p>
        }
        else if (allTracks.Count == 0)
        {
            <p>Geen tracks gevonden in de database.</p>
        }
        else
        {
            <div class="row">
                @foreach (var track in allTracks)
                {
                    <div class="col-md-3 mb-3">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title text-truncate">@track.Title</h5>
                                <h6 class="card-subtitle mb-2 text-muted">@track.UploaderName</h6>
                                <span class="badge bg-primary">@track.TrackGenre</span>
                                <div class="mt-3">
                                    <button class="btn btn-outline-success btn-sm w-100" @onclick="() => PlayTrack(track)">
                                        ▶ Afspelen
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <hr class="my-5" />

        @* --- SECTIE 2: ALLE PLAYLISTS --- *@
        <h3 class="section-title">📂 Publieke Playlists</h3>
        @if (allPlaylists == null)
        {
            <p><em>Playlists laden...</em></p>
        }
        else if (allPlaylists.Count == 0)
        {
            <p>Geen playlists gevonden.</p>
        }
        else
        {
            <div class="row">
                @foreach (var playlist in allPlaylists)
                {
                    <div class="col-md-3 mb-3">
                        <div class="card shadow-sm border-info">
                            <div class="card-body">
                                <h5 class="card-title text-truncate">@playlist.PlaylistName</h5>
                                <h6 class="card-subtitle mb-2 text-muted">@playlist.PlaylistGenre</h6>
                                <span class="badge bg-info text-dark">@playlist.PlaylistTags</span>
                                <div class="mt-3">
                                    <button class="btn btn-outline-info btn-sm w-100" @onclick="async () => await PlayPlaylist(playlist)">
                                        ▶ Afspelen
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private bool isCheckingLogin = true;
    private List<TrackModel>? allTracks;
    private List<Playlistmodel>? allPlaylists;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // 1. Kijk of de service is gereset (bijv. door een F5 refresh)
                if (!Userstate.IsLoggedIn)
                {
                    var storedUserId = await ProtectedLocalStore.GetAsync<int>("userId");
                    var storedUserName = await ProtectedLocalStore.GetAsync<string>("userName");

                    if (storedUserId.Success && storedUserName.Success)
                    {
                        // Sessie hersteld!
                        Userstate.LogIn(storedUserId.Value, storedUserName.Value);
                    }
                    else
                    {
                        // Geen opgeslagen sessie gevonden, ga terug naar inloggen
                        NavigationManager.NavigateTo("/");
                        return;
                    }
                }

                // 2. Laad de muziekdata uit de API in
                await LoadMusicData();
            }
            catch (Exception)
            {
                // Als de browserdata corrupt is of fouten geeft, stuur ze terug naar login
                NavigationManager.NavigateTo("/");
                return;
            }
            finally
            {
                // Zorg dat het laadscherm weggaat
                isCheckingLogin = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadMusicData()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            allTracks = await client.GetFromJsonAsync<List<TrackModel>>("tracks");
            allPlaylists = await client.GetFromJsonAsync<List<Playlistmodel>>("playlists");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fout bij inladen discover data: {ex.Message}");
            allTracks = new List<TrackModel>();
            allPlaylists = new List<Playlistmodel>();
        }
    }

    // --- Actie Methodes (MixVault Stijl) ---

    // 1. Voor enkele nummers (Alle Tracks)
    private void PlayTrack(TrackModel track)
    {
        if (track != null && !string.IsNullOrEmpty(track.TrackFileUrl))
        {
            AudioState.PlayTrack(track.Title ?? "Onbekende Track", track.TrackFileUrl);
        }
    }

    // 2. Voor nummers IN een playlist
    private void PlayPlaylistTrack(PlaylistTrackModel track)
    {
        if (track != null && !string.IsNullOrEmpty(track.TrackFileUrl))
        {
            AudioState.PlayTrack(track.Title ?? "Onbekende Track", track.TrackFileUrl);
        }
    }

    // 3. Om een hele playlist af te spelen (begint bij het eerste nummer)
    private async Task PlayPlaylist(Playlistmodel playlist)
    {
        var client = HttpClientFactory.CreateClient("MixVaultAPI");
        try
        {
            // Haal de tracks op van deze specifieke playlist
            var playlistTracks = await client.GetFromJsonAsync<List<PlaylistTrackModel>>($"playlists/{playlist.PlaylistId}/tracks");

            if (playlistTracks != null && playlistTracks.Any())
            {
                var firstTrack = playlistTracks.First();
                PlayPlaylistTrack(firstTrack);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fout bij het afspelen van playlist tracks: {ex.Message}");
        }
    }

    // --- DTO Classes (MixVault Uniform Stijl) ---

    public class TrackModel
    {
        public int TrackId { get; set; }
        public string? Title { get; set; }
        public double? DurationMs { get; set; }
        public string? TrackGenre { get; set; }
        public string? UploaderName { get; set; }
        public string? TrackFileUrl { get; set; }
    }

    public class PlaylistTrackModel
    {
        public int? Position { get; set; }
        public int TrackId { get; set; }
        public string? Title { get; set; }
        public double? Duration { get; set; }
        public string? TrackFileUrl { get; set; }
    }

    public class Playlistmodel
    {
        public int PlaylistId { get; set; }
        public string? PlaylistName { get; set; }
        public string? PlaylistDescription { get; set; }
        public string? PlaylistGenre { get; set; }
        public string? PlaylistTags { get; set; }
    }
}