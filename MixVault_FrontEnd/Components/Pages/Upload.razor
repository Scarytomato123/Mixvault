@page "/upload"
@rendermode InteractiveServer
@using System.IO
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject MixVault_FrontEnd.Services.Userstate UserState

<PageTitle>MixVault - Upload</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="mv-card p-5 shadow">
                <h2 class="fw-bold mb-2">Nieuwe Mix of Track Uploaden</h2>
                <p class="text-muted mb-4">Kies een audiobestand. MixVault leest automatisch de ID3-tags uit via MediaHuman metadata.</p>

                @* SLEEP/KIES BESTAND ZONE *@
                <div class="mb-4 p-4 text-center rounded" style="border: 2px dashed var(--accent-pink); background-color: rgba(255, 64, 129, 0.05);">
                    <label for="fileUpload" class="form-label d-block fw-bold mb-0" style="cursor: pointer; color: white;">
                        🎵 Klik hier om een MP3 / WAV te kiezen
                    </label>
                    <InputFile id="fileUpload" OnChange="HandleFileSelected" class="form-control d-none" accept=".mp3,.wav" />

                    @if (selectedFile != null)
                    {
                        <div class="mt-3 text-white fw-bold">
                            Geselecteerd: <span style="color: var(--accent-pink);">@selectedFile.Name</span> (@(selectedFile.Size / 1024 / 1024) MB)
                        </div>
                    }
                </div>

                @* INVOERVELDEN (Auto-gevuld maar aanpasbaar) *@
                <div class="mb-3">
                    <label class="form-label text-uppercase small fw-bold" style="color: var(--text-soft);">Titel</label>
                    <input type="text" class="form-control" @bind="trackTitle" placeholder="" />
                </div>

                <div class="mb-3">
                    <label class="form-label text-uppercase small fw-bold" style="color: var(--text-soft);">Artiest / DJ</label>
                    <input type="text" class="form-control" @bind="trackArtist" placeholder="" />
                </div>

                <div class="mb-4">
                    <label class="form-label text-uppercase small fw-bold" style="color: var(--text-soft);">Genre</label>
                    <input type="text" class="form-control" @bind="trackGenre" placeholder="" />
                </div>

                @* AKTION KNOP *@
                <button class="btn btn-mv-accent w-100 py-3 fw-bold fs-5" @onclick="UploadTrack" disabled="@isUploading">
                    @if (isUploading)
                    {
                        <span>⏳ Uploaden en verwerken...</span>
                    }
                    else
                    {
                        <span>🚀 Mix Veilig Opslaan</span>
                    }
                </button>

                @* STATUS *@
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert mt-4 text-center" style="background-color: rgba(255,64,129,0.2); color: white; border: 1px solid var(--accent-pink);">
                        @statusMessage
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private IBrowserFile? selectedFile;
    private string trackTitle = string.Empty;
    private string trackArtist = string.Empty;
    private string trackGenre = string.Empty;
    private double trackDurationMs = 0; // <-- NIEUW: Slaat de uitgelezen milliseconden op!
    private bool isUploading = false;
    private string statusMessage = string.Empty;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        if (selectedFile == null) return;

        statusMessage = "⏳ Metadata (ID3 tags) uitlezen...";
        StateHasChanged();

        try
        {
            // We lezen de bytes van de geüploade mp3 in het geheugen
            using var memoryStream = new MemoryStream();
            await selectedFile.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024).CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var fileAbstraction = new StreamFileAbstraction(selectedFile.Name, memoryStream);
            using var tags = TagLib.File.Create(fileAbstraction);

            if (tags != null && tags.Tag != null)
            {
                trackTitle = !string.IsNullOrEmpty(tags.Tag.Title) ? tags.Tag.Title : Path.GetFileNameWithoutExtension(selectedFile.Name);
                trackArtist = !string.IsNullOrEmpty(tags.Tag.FirstPerformer) ? tags.Tag.FirstPerformer : string.Empty;
                trackGenre = !string.IsNullOrEmpty(tags.Tag.FirstGenre) ? tags.Tag.FirstGenre : string.Empty;

                // --- NIEUW: Pak direct de exacte tijdsduur van de track ---
                if (tags.Properties != null)
                {
                    trackDurationMs = tags.Properties.Duration.TotalMilliseconds;
                }

                statusMessage = "✅ Metadata succesvol uitgelezen!";
            }
        }
        catch (Exception ex)
        {
            trackTitle = Path.GetFileNameWithoutExtension(selectedFile.Name);
            trackDurationMs = 0;
            statusMessage = "⚠️ Geen ID3-tags gevonden, bestandsnaam gebruikt als titel.";
            Console.WriteLine($"TagLib error: {ex.Message}");
        }
    }

    public class StreamFileAbstraction : TagLib.File.IFileAbstraction
    {
        public StreamFileAbstraction(string name, Stream stream)
        {
            Name = name;
            ReadStream = stream;
            WriteStream = stream;
        }

        public string Name { get; }
        public Stream ReadStream { get; }
        public Stream WriteStream { get; }

        public void CloseStream(Stream stream) { }
    }

    private async Task UploadTrack()
    {
        if (selectedFile == null)
        {
            statusMessage = "❌ Selecteer eerst een bestand!";
            return;
        }

        isUploading = true;
        statusMessage = "⏳ Bestand en data worden verzonden...";

        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");
            using var content = new MultipartFormDataContent();

            // Voeg het audiobestand toe aan de request stream
            var fileStream = selectedFile.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            var streamContent = new StreamContent(fileStream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType);
            content.Add(streamContent, "file", selectedFile.Name);

            // Voeg de basistekstvelden toe
            content.Add(new StringContent(trackTitle), "title");
            content.Add(new StringContent(trackArtist), "artist");
            content.Add(new StringContent(trackGenre), "genre");

            // Haal de ID van de ingelogde DJ op uit je UserState
            content.Add(new StringContent(UserState.UserID.ToString()), "fkUser");

            // --- NIEUW: Stuur de exacte tracklengte mee naar de API! ---
            content.Add(new StringContent(trackDurationMs.ToString()), "durationMs");

            var response = await client.PostAsync("tracks", content);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "🎉 Mix succesvol opgeslagen in je MixVault!";
                await Task.Delay(1500);
                NavigationManager.NavigateTo($"/MixVault/{UserState.UserID}");
            }
            else
            {
                statusMessage = $"❌ Fout bij API: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"❌ Fout tijdens uploaden: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }
}