@page "/register"
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer

<div class="login-container">
    <div class="mv-card p-4" style="max-width: 400px; width: 100%;">
        <div class="login-header">
            <h3 style="color: white;">Account Aanmaken</h3>
            <p style="color: var(--text-soft); font-size: 14px;">Word lid van de MixVault community</p>
        </div>

        <div class="form-group mb-3">
            <label style="color: var(--text-soft); display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px; text-transform: uppercase;">Gebruikersnaam</label>
            <input class="form-control" @bind="username" placeholder="" />
        </div>

        <div class="form-group mb-4">
            <label style="color: var(--text-soft); display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px; text-transform: uppercase;">Wachtwoord</label>
            <input type="password" class="form-control" @bind="password" placeholder="" />
        </div>

        <button class="btn btn-mv-accent w-100 py-2" @onclick="RegisterUser">Registreren</button>

        @if (ErrorMessage != null)
        {
            <div class="message error mt-3" style="background: rgba(220, 38, 38, 0.2); color: #fca5a5; border: none; border-radius: 8px; padding: 10px; text-align: center; font-size: 14px;">
                ⚠️ @ErrorMessage
            </div>
        }

        @if (SuccessMessage != null)
        {
            <div class="message success mt-3" style="background: rgba(5, 150, 105, 0.2); color: #a7f3d0; border: none; border-radius: 8px; padding: 10px; text-align: center; font-size: 14px;">
                ✅ @SuccessMessage
            </div>
        }

        <div class="text-center mt-3">
            <a href="login" style="color: var(--accent-pink); text-decoration: none; font-size: 14px;">Al een account? Log hier in</a>
        </div>
    </div>
</div>

@code {
    private string username { get; set; } = string.Empty;
    private string password { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }

    private async Task RegisterUser()
    {
        try
        {
            ErrorMessage = null;
            SuccessMessage = null;

            if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
            {
                ErrorMessage = "Vul aankoopgegevens/velden volledig in.";
                return;
            }

            var client = HttpClientFactory.CreateClient("MixVaultAPI");

            // We sturen de data door naar je API register endpoint
            var registerData = new { Username = username, Password = password};
            var response = await client.PostAsJsonAsync("users/register", registerData);

            if (response.IsSuccessStatusCode)
            {
                SuccessMessage = "Account succesvol aangemaakt! Je wordt doorgestuurd...";
                StateHasChanged();

                // Wacht 2 seconden zodat de gebruiker het succesbericht ziet, stuur dan door naar login
                await Task.Delay(200);
                Navigation.NavigateTo("login");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                ErrorMessage = !string.IsNullOrEmpty(errorContent) ? errorContent : "Registratie mislukt. Gebruikersnaam bestaat mogelijk al.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Fout bij verbinden met server: {ex.Message}";
        }
    }
}

