@page "/login"
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Userstate UserState
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedLocalStorage ProtectedLocalStore
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory



<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .login-card {
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        width: 100%;
        max-width: 400px;
        border: 1px solid #f0f0f0;
    }

    .login-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .login-header h3 {
        font-size: 24px;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 10px;
    }

    .login-header p {
        color: #6b7280;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border-radius: 10px;
        border: 2px solid #e5e7eb;
        transition: all 0.2s;
        font-size: 16px;
        box-sizing: border-box;
    }

    .form-control:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }

    .btn-login {
        width: 100%;
        background: #6366f1;
        color: white;
        border: none;
        padding: 14px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.3s;
        margin-top: 10px;
    }

    .btn-login:hover {
        background: #4f46e5;
    }

    .message {
        padding: 12px;
        border-radius: 8px;
        margin-top: 20px;
        font-size: 14px;
        text-align: center;
    }

    .error { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
    .success { background: #ecfdf5; color: #059669; border: 1px solid #d1fae5; }
</style>

<div class="login-container">
    @* We gebruiken hier de mv-card klasse uit app.css *@
    <div class="mv-card p-4" style="max-width: 400px; width: 100%;">
        <div class="login-header">
            <h3 style="color: white;">Welkom terug!</h3>
        </div>

        <div class="form-group">
            <label style="color: var(--text-soft);">Gebruikersnaam</label>
            @* De form-control klasse wordt door app.css al donker gemaakt *@
            <input class="form-control" @bind="username" />
        </div>

        <div class="form-group">
            <label style="color: var(--text-soft);">Wachtwoord</label>
            <input type="password" class="form-control" @bind="password" />
        </div>

        @* Gebruik hier de btn-mv-accent klasse uit app.css *@
        <button class="btn btn-mv-accent w-100 py-2" @onclick="SubmitBucketListItem">Inloggen</button>

        @if (ErrorMessage != null)
        {
            <div class="message error mt-3" style="background: rgba(220, 38, 38, 0.2); color: #fca5a5; border: none; border-radius: 8px; padding: 10px;">
                ⚠️ @ErrorMessage
            </div>
        }
    </div>
</div>

@code {
    private string username { get; set; } = string.Empty;
    private string password { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }
    private async Task SubmitBucketListItem()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("MixVaultAPI");

            var url = $"/login?username={Uri.EscapeDataString(username)}&password={Uri.EscapeDataString(password)}";
            var response = await client.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var userData = await response.Content.ReadFromJsonAsync<UserResponse>();

                if (userData != null)
                {
                    // 1. Vertel de app dat we ingelogd zijn (dit laat de knop in NavMenu verschijnen!)
                    UserState.LogIn(userData.IdUser, userData.NameUser);

                    // 2. Sla het veilig op in de browser (dit fixt de F5 refresh bug!)
                    await ProtectedLocalStore.SetAsync("userId", userData.IdUser);
                    await ProtectedLocalStore.SetAsync("userName", userData.NameUser);

                    // 3. Stuur de gebruiker door naar zijn kluis
                    Navigation.NavigateTo($"/MixVault/{userData.IdUser}");
                }
            }
            else
            {
                ErrorMessage = "Inloggen mislukt.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Fout: {ex.Message}";
            Console.WriteLine(ex.ToString());
        }
    }

    public class UserResponse
    {
        public int IdUser { get; set; }
        public string NameUser { get; set; } = string.Empty;
    }
}