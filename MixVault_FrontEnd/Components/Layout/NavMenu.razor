@rendermode InteractiveServer
@implements IDisposable
@inject MixVault_FrontEnd.Services.Userstate Userstate

@* 1. Het Logo bovenaan, gefixeerd op 50px *@
<div class="top-row ps-3 navbar navbar-dark" style="height: 50px; padding: 0;">
    <div class="container-fluid justify-content-center">
        <a class="navbar-brand d-flex align-items-center justify-content-center" href="" style="margin: 0; padding: 0;">
            <img src="/logo.png" alt="MixVault Logo" style="height: 50px; width: auto;" />
        </a>
    </div>
</div>

@* 2. De rest van het menu in een aparte scrollbare sectie *@
<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/login">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Login
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/register">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Register
            </NavLink>
        </div>

        @if (Userstate.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="discover">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Discover
                </NavLink>
            </div>
        }

        @if (Userstate.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"MixVault/{Userstate.UserID}")">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Mijn MixVault
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"Upload")">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Upload
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Userstate.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Userstate.OnChange -= StateHasChanged;
    }
}