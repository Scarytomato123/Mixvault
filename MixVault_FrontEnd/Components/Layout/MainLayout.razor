@inherits LayoutComponentBase
@inject MixVault_FrontEnd.Services.AudioState AudioState
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <div class="content px-4" style="padding-bottom: 100px;">
            @Body
        </div>
    </main>
</div>

@* --- GLOBAL AUDIO PLAYER BAR --- *@
@if (!string.IsNullOrEmpty(AudioState.CurrentTrackUrl))
{
    <div class="fixed-bottom bg-dark text-white p-3 shadow-lg d-flex align-items-center justify-content-between animate-fade-in" style="z-index: 1050; height: 80px;">
        <div class="text-truncate me-3" style="max-width: 300px;">
            <h6 class="mb-0 text-truncate fw-bold text-success">Nu aan het afspelen:</h6>
            <small class="text-white-50 text-truncate">@AudioState.CurrentTrackTitle</small>
        </div>

        <div class="flex-grow-1 px-4">
            @* GEWIJZIGD: We gebruiken AudioState.PlayId als @key! 
               Hierdoor snapt Blazor dat de player hard gereset moet worden bij ELKE klik. *@
            <audio @key="AudioState.PlayId" id="global-audio-player" src="@AudioState.CurrentTrackUrl" controls autoplay class="w-100">
                Je browser ondersteunt dit audio-element niet.
            </audio>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        AudioState.OnTrackChanged += UpdatePlayer;
    }

    // GEWIJZIGD: Omdat AudioState globaal is, MOETEN we InvokeAsync gebruiken
    // om de pagina netjes te verversen zonder vast te lopen.
    private void UpdatePlayer()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AudioState.OnTrackChanged -= UpdatePlayer;
    }
}