@rendermode InteractiveServer
@implements IDisposable
@inject MixVault_FrontEnd.Services.AudioState AudioState
@inject NavigationManager NavigationManager

@if (!string.IsNullOrEmpty(AudioState.CurrentTrackUrl) && !IsAuthPage())
{
    <div class="audio-player-bar shadow-lg border-top" style="border-top: 2px solid var(--accent-pink) !important;">
        <div class="container-fluid h-100 d-flex align-items-center justify-content-between px-4">

            <div class="track-info text-truncate" style="max-width: 300px;">
                <span class="text-white d-block text-truncate" style="font-size: 0.8rem; opacity: 0.7;">NU AAN HET AFSPELEN</span>
                <strong class="text-white text-truncate d-block" title="@AudioState.CurrentTrackTitle">
                    @AudioState.CurrentTrackTitle
                </strong>
            </div>

            <div class="player-controls flex-grow-1 px-5">
                @* De player zelf krijgt via CSS een kleine 'restyle' *@
                <audio @key="AudioState.PlayId" controls autoplay class="w-100 custom-audio-element">
                    <source src="@AudioState.CurrentTrackUrl" type="audio/mpeg" />
                </audio>
            </div>

            <div class="player-options text-end">
                <button class="btn btn-sm" style="color: var(--accent-pink); border: 1px solid var(--accent-pink);" @onclick="StopPlayer">
                    SLUITEN
                </button>
            </div>
        </div>
    </div>
}

<style>
    .audio-player-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 85px;
        background-color: var(--bg-dark); /* Diep paars */
        z-index: 9999;
        padding: 10px 0;
    }

    /* Roze accenten in de standaard browser player */
    .custom-audio-element {
        accent-color: var(--accent-pink);
    }
</style>

@code {
    protected override void OnInitialized()
    {
        AudioState.OnTrackChanged += StateHasChanged;
        NavigationManager.LocationChanged += (s, e) => StateHasChanged();
    }

    private bool IsAuthPage()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower();
        return string.IsNullOrEmpty(relativePath) || relativePath.StartsWith("login");
    }

    private void StopPlayer() => AudioState.PlayTrack("", "");

    public void Dispose() => AudioState.OnTrackChanged -= StateHasChanged;
}